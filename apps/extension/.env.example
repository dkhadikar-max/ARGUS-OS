# Vite loads these directly from apps/extension/.env (copy this file there)
# — the root .env.example's own note on this is just a pointer, Vite never
# reads the repo root's .env for this workspace. VITE_-prefixed so they're
# inlined into the bundled background/content scripts at build time.

# Where the background service worker fetches the ARGUS API, and what
# manifest.config.ts declares in host_permissions (kept in sync by reading
# this same var — see that file's own comment). Defaults to localhost if
# unset, matching local dev with apps/api running via `npm run dev`.
#
# For a real Chrome Web Store submission, set this to the deployed
# argus-api URL (Bible §18 INF-1's Render blueprint) before running
# `npm run build` — a build shipped with this still pointed at localhost
# would be permanently non-functional for every end user.
VITE_API_BASE_URL="http://localhost:4000"

# Where the sidebar sends an unauthenticated rep to sign in (Bible §7.2
# EXT-5 -- the full Clerk OAuth handshake lives in the dashboard, not the
# extension). Same "must be the real deployed URL before a Chrome Web Store
# build" requirement as VITE_API_BASE_URL above.
VITE_DASHBOARD_URL="http://localhost:3000"

# PostHog client key (Bible §11.1) — public/embeddable, unlike the
# server-side POSTHOG_API_KEY apps/api uses.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://app.posthog.com"
