# ── Database (Bible §7.2, §9.1) ──────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/argus?schema=public"

# ── Cache / Queue (Bible §9.2) ────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AI Provider (Bible §7.2, §8) ──────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Enrichment (Bible §7.1, §18 AI-2) ─────────────────────────
# Apollo: from Settings > Integrations > API in your Apollo.io account.
# Sent as an `x-api-key` header (verified against Apollo's own current docs).
APOLLO_API_KEY=""
# Clearbit: your Clearbit secret key. Sent as HTTP Basic auth (key as
# username, empty password) -- verified against Clearbit's own official
# Node client source, since their public docs now sit behind a login wall.
CLEARBIT_API_KEY=""

# ── Vector DB (Bible §9.3) ────────────────────────────────────
PINECONE_API_KEY=""
PINECONE_INDEX="argus-prospects"

# ── Auth — Clerk.dev (Bible §7.2, §10.1) ──────────────────────
CLERK_JWT_ISSUER=""
CLERK_JWKS_URL=""
# From your Clerk Dashboard's Webhooks page (endpoint: POST /api/v1/webhooks/clerk).
# Provisions the User+Team row a Clerk sign-up needs before any JWT-authenticated
# request can succeed — see apps/api/src/modules/webhooks.
CLERK_WEBHOOK_SECRET=""

# ── Slack Bot integration (Bible §18 Epic 3) ──────────────────
# Shared secret between apps/api and apps/slack-bot's server-to-server
# integration-resolution calls. Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=""

# ── Data encryption at rest (Bible §18 INF-4) ─────────────────
# Encrypts Integration.config's secret fields (Slack bot token, generated
# API key) with AES-256-GCM — see apps/api/src/lib/encryption.ts. Optional
# at boot (a checkout that never touches Slack integrations still runs),
# but connecting/resolving Slack throws a clear error without it, rather
# than silently falling back to plaintext. Must be exactly 32 bytes of hex
# (64 characters). Generate with: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=""

# ── Slack OAuth self-serve install (Bible §18 SLK-1) ──────────
# From the Slack app's "OAuth & Permissions" page. The redirect URL
# registered there must exactly match PUBLIC_API_URL + the fixed callback
# path below (verified against Slack's own current OAuth v2 docs).
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
# This server's own public-facing URL — used to build the OAuth
# redirect_uri (.../api/v1/integrations/slack/oauth/callback).
PUBLIC_API_URL="http://localhost:4000"
# Where the OAuth callback sends the browser after connecting (success or
# failure) — reuses the dashboard's Today Queue page.
DASHBOARD_URL="http://localhost:3000"

# ── API Server ─────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"
CORS_ALLOWED_ORIGINS="chrome-extension://,http://localhost:3000"

# ── Rate Limits (Bible §19.1 Security) ────────────────────────
RATE_LIMIT_FREE_PER_HOUR="100"
RATE_LIMIT_PAID_PER_HOUR="500"

# ── Observability (Bible §7.2) ─────────────────────────────────
SENTRY_DSN=""
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"
# Bible §18 INF-2 "Datadog / Railway metrics" -- request-level infra metrics
# (latency, throughput, error rate), sent over UDP via StatsD to a Datadog
# Agent. Optional; no-ops safely without it. 8125 is the Agent's own
# documented default StatsD port.
DATADOG_AGENT_HOST=""
DATADOG_AGENT_PORT="8125"

# ── apps/slack-bot only (Bible §18 Epic 3) ────────────────────
# From the Slack app's Basic Information page — Socket Mode needs no
# public URL, so no OAuth redirect URI is required.
SLACK_APP_TOKEN=""       # xapp-... (Socket Mode)
SLACK_SIGNING_SECRET=""
API_BASE_URL="http://localhost:4000"
# INTERNAL_SERVICE_TOKEN and REDIS_URL above are shared with apps/api

# ── apps/dashboard only (Bible §18 Epic 5) ────────────────────
# From your Clerk Dashboard's API Keys page — distinct from
# CLERK_JWT_ISSUER/CLERK_JWKS_URL above, which are apps/api's own manual
# JWT verification, not the Clerk Next.js SDK's config.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# API_BASE_URL above is reused for the dashboard's server-side API calls.
# NEXT_PUBLIC_API_BASE_URL is the same address again, but exposed to the
# browser bundle -- needed because Bible §10.6's WebSocket connection is
# opened client-side (a live queue feed), unlike every other dashboard-to-
# apps/api call, which stays server-side via Next.js Server Components.
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
# Bible §11.1 event tracking (queue_viewed/queue_item_clicked) -- same
# NEXT_PUBLIC_ requirement as above, since PostHog only runs in the
# browser. Public/embeddable client key, unlike apps/api's server-side
# POSTHOG_API_KEY above.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── apps/extension only (Bible §18 Epic 1, §11.1) ─────────────
# Vite loads these from apps/extension/.env (not this root file) —
# VITE_-prefixed so they're inlined into the bundled content script at
# build time. PostHog's client key is meant to be public/embeddable
# (like a Stripe publishable key), unlike the server-side POSTHOG_API_KEY
# above, which is a private key and must never end up in browser code.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://app.posthog.com"
