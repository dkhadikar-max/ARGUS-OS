# ── Database (Bible §7.2, §9.1) ──────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/argus?schema=public"

# ── Cache / Queue (Bible §9.2) ────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AI Provider (Bible §7.2, §8) ──────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Enrichment (Bible §7.1, §18 AI-2) ─────────────────────────
APOLLO_API_KEY=""
CLEARBIT_API_KEY=""

# ── Vector DB (Bible §9.3) ────────────────────────────────────
PINECONE_API_KEY=""
PINECONE_INDEX="argus-prospects"

# ── Auth — Clerk.dev (Bible §7.2, §10.1) ──────────────────────
CLERK_JWT_ISSUER=""
CLERK_JWKS_URL=""

# ── Slack Bot integration (Bible §18 Epic 3) ──────────────────
# Shared secret between apps/api and apps/slack-bot's server-to-server
# integration-resolution calls. Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=""

# ── API Server ─────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"
CORS_ALLOWED_ORIGINS="chrome-extension://,http://localhost:3000"

# ── Rate Limits (Bible §19.1 Security) ────────────────────────
RATE_LIMIT_FREE_PER_HOUR="100"
RATE_LIMIT_PAID_PER_HOUR="500"

# ── Observability (Bible §7.2) ─────────────────────────────────
SENTRY_DSN=""
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ── apps/slack-bot only (Bible §18 Epic 3) ────────────────────
# From the Slack app's Basic Information page — Socket Mode needs no
# public URL, so no OAuth redirect URI is required.
SLACK_APP_TOKEN=""       # xapp-... (Socket Mode)
SLACK_SIGNING_SECRET=""
API_BASE_URL="http://localhost:4000"
# INTERNAL_SERVICE_TOKEN and REDIS_URL above are shared with apps/api
